# Supabase — proyecto galicia-migrante
# Obtener en: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Conexión directa a PostgreSQL (solo para scripts/apply_migrations.js)
# Obtener en: https://supabase.com/dashboard/project/<ref>/settings/database
SUPABASE_DB_HOST=db.<ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
